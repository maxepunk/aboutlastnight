# About Last Night - emailer secrets.
#
# Copy this file to ".env" (same folder) and fill in the real value:
#     copy .env.example .env       (Windows)
#
# ".env" is gitignored and must NEVER be committed - this repo is public.
# The script loads ".env" automatically when it runs; a real environment
# variable (e.g. set via setx) still takes precedence if you have both.
#
# Value = the 16-character Gmail app password for about.last.night.game@gmail.com
# (generate at https://myaccount.google.com/apppasswords), with the spaces removed.
ALN_GMAIL_APP_PASSWORD=your16charapppassword
